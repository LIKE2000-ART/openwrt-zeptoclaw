From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: yalike <noreply@example.com>
Date: Mon, 2 Mar 2026 14:00:00 +0800
Subject: [PATCH] channels: lark choose receive_id_type based on id prefix

Feishu returns `open_id cross app` when a chat id is sent with
`receive_id_type=open_id`. The upstream code currently sends `msg.chat_id`
but always uses `open_id`.

Infer receive id type from the runtime target id:
- `ou_` => open_id
- others => chat_id
---
 src/channels/lark.rs | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/src/channels/lark.rs b/src/channels/lark.rs
index c7f7f2d..3fd23b2 100644
--- a/src/channels/lark.rs
+++ b/src/channels/lark.rs
@@ -999,10 +999,14 @@ impl Channel for LarkChannel {
             .await
             .map_err(|e| ZeptoError::Channel(format!("Lark: failed to get tenant token: {e}")))?;
 
-        let url = format!("{}/im/v1/messages?receive_id_type=open_id", self.api_base());
+        let receive_id = msg.chat_id;
+        let receive_id_type = if receive_id.starts_with("ou_") {
+            "open_id"
+        } else {
+            "chat_id"
+        };
+        let url = format!("{}/im/v1/messages?receive_id_type={receive_id_type}", self.api_base());
         let content = serde_json::json!({ "text": msg.content }).to_string();
         let body = serde_json::json!({
-            "receive_id": msg.chat_id,
+            "receive_id": receive_id,
             "msg_type":   "text",
             "content":    content,
         });
